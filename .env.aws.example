# Application
APP_NAME=fraud-rule-engine
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
API_KEY=<generate-a-secure-key>

# Database (RDS PostgreSQL) — populated from Terraform outputs
DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<rds-endpoint>:5432/fraud_engine

# Cache (ElastiCache Redis) — populated from Terraform outputs
REDIS_URL=redis://<elasticache-endpoint>:6379/0

# AWS Services (real AWS)
AWS_REGION=af-south-1
# AWS_ENDPOINT_URL is intentionally unset — use real AWS endpoints
SQS_QUEUE_URL=<from-terraform-output>
SNS_TOPIC_ARN=<from-terraform-output>
S3_BUCKET_NAME=<from-terraform-output>

# Event Processing
SYNC_MODE=false
SQS_POLL_INTERVAL_SECONDS=5
SQS_MAX_MESSAGES=10
