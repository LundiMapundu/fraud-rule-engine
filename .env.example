# Application
APP_NAME=fraud-rule-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
API_KEY=dev-api-key-change-me

# Database (RDS PostgreSQL)
DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass@localhost:5432/fraud_engine

# Cache (ElastiCache Redis)
REDIS_URL=redis://localhost:6379/0

# AWS Services (LocalStack for local dev)
AWS_REGION=af-south-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_QUEUE_URL=http://localhost:4566/000000000000/fraud-engine-transactions
SNS_TOPIC_ARN=arn:aws:sns:af-south-1:000000000000:fraud-alerts
S3_BUCKET_NAME=fraud-engine-audit

# Event Processing
SYNC_MODE=false
SQS_POLL_INTERVAL_SECONDS=1
SQS_MAX_MESSAGES=10
